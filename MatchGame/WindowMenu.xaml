<Window x:Class="MatchGame.WindowMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MatchGame"
        mc:Ignorable="d"
        Title="WindowMenu" Height="450" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock TextWrapping="Wrap" Text="Jogo da Memória" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36"/>
        <Button Content="Começar" HorizontalAlignment="Center" Grid.Row="1" VerticalAlignment="Center" FontSize="36" Foreground="#FF299819" BorderThickness="1,1,1,1" Click="StartButton_Click"/>
        <TextBlock x:Name="bestTimeTextBlock" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Melhor Tempo" VerticalAlignment="Top" FontSize="20" Margin="0,172,0,0"/>

    </Grid>
</Window>
